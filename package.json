{
  "name": "nbeamng-backend",
  "version": "0.1.0",
  "description": "NbeamNG Backend Platform — Governed dynamic agent workspace for acquisition-target investment analysis",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "test": "jest",
    "test:integration": "jest --testPathPattern=integration",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0",
    "express": "^4.19.2",
    "minio": "^8.0.0",
    "pdf-parse": "^1.1.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "prisma": "^5.15.0",
    "ts-jest": "^29.1.5",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": ["investment-analysis", "agent-workspace", "backend"],
  "license": "UNLICENSED"
}