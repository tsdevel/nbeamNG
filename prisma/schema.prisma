generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────

enum ProjectStatus {
  active
  under_review
  completed
  archived
  purged_confidential
  purged
}

enum ConfidentialityClass {
  confidential
  public
  unknown
}

enum ArtifactType {
  raw_upload
  extracted_text
  structured_data
  research_summary
  claim
  evidence
  data_need
  review_comment
  report
}

enum ArtifactStatus {
  draft
  verified
  approved
  superseded
  deleted
}

enum TaskStatus {
  pending
  claimed
  in_progress
  completed
  failed
}

enum AgentRunStatus {
  pending
  claimed
  in_progress
  completed
  failed
}

enum DataNeedStatus {
  open
  resolving
  resolved
  estimated
  unavailable
  needs_human_input
}

enum ClaimType {
  financial_fact
  operational_kpi
  market_fact
  valuation_input
  management_assertion
  calculated_metric
  analyst_judgment
  risk
  hypothesis
}

enum ClaimStatus {
  draft
  supported
  unsupported
  needs_review
  invalidated
}

enum ReviewCommentType {
  correction
  new_evidence
  judgment_change
  style_change
  question
  approval
}

enum EvidenceReliability {
  audited_filing
  management_assertion
  analyst_estimate
  third_party_verified
  unverified
}

// ─── Models ──────────────────────────────────────────────────────────

model Project {
  id                    String               @id @default(cuid())
  customer_id           String
  name                  String
  target_company        String?
  description           String?
  confidentiality_class ConfidentialityClass   @default(unknown)
  status                ProjectStatus        @default(active)
  retention_policy      String? // Reserved; sophisticated config deferred to later slices
  created_at            DateTime             @default(now())
  updated_at            DateTime             @updatedAt

  workspace_versions WorkspaceVersion[]
  artifacts          Artifact[]
  events             Event[]
  tasks              Task[]
  agent_runs         AgentRun[]
  data_needs         DataNeed[]
  claims             Claim[]
  evidence           Evidence[]
  review_comments    ReviewComment[]

  @@index([customer_id])
  @@index([status])
  @@index([customer_id, status])
}

model WorkspaceVersion {
  id                String   @id @default(cuid())
  project_id        String
  project           Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  customer_id       String
  version_number    Int
  parent_version_id String?
  created_at        DateTime @default(now())

  artifacts       Artifact[]
  claims            Claim[]
  review_comments   ReviewComment[]

  @@unique([project_id, version_number])
  @@index([project_id])
  @@index([customer_id])
}

model Artifact {
  id                   String         @id // Deterministic: generated in service layer for idempotency
  project_id           String
  project              Project        @relation(fields: [project_id], references: [id], onDelete: Cascade)
  workspace_version_id String
  workspace_version    WorkspaceVersion @relation(fields: [workspace_version_id], references: [id], onDelete: Cascade)
  customer_id          String
  type                 ArtifactType
  name                 String
  mime_type            String?
  storage_bucket       String?
  storage_key          String?
  file_hash            String? // SHA-256 for idempotency of raw uploads
  extracted_text       String?  @db.Text
  source_artifact_ids  String[] // Lightweight lineage for Slice 1; join tables in later slices
  status               ArtifactStatus @default(draft)
  metadata             Json? // Flexible schema per artifact type
  created_at           DateTime       @default(now())
  updated_at           DateTime       @updatedAt

  @@index([project_id])
  @@index([workspace_version_id])
  @@index([customer_id])
  @@index([type])
  @@index([file_hash])
  @@index([project_id, file_hash, type])
  @@index([customer_id, type, status])

  claims   Claim[]
  evidence Evidence[]
}

model Event {
  id          String   @id @default(cuid())
  project_id  String?
  project     Project? @relation(fields: [project_id], references: [id], onDelete: SetNull)
  customer_id String
  tenant_id   String // Same as customer_id; explicit naming for audit clarity
  event_type  String
  payload     Json
  occurred_at DateTime @default(now())

  @@index([project_id])
  @@index([customer_id])
  @@index([tenant_id])
  @@index([event_type])
  @@index([occurred_at])
  @@index([project_id, event_type, occurred_at])
}

model Task {
  id              String    @id @default(cuid())
  project_id      String
  project         Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  customer_id     String
  type            String    // e.g., "research", "claim_extraction", "verification"
  status          TaskStatus @default(pending)
  capability      String    // e.g., "research", "pdf_ingestion"
  payload         Json
  lease_expires_at DateTime?
  heartbeat_at    DateTime?
  claimed_by      String?
  attempts        Int       @default(0)
  max_attempts    Int       @default(3)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  agent_runs AgentRun[]

  @@index([project_id, status])
  @@index([customer_id, status])
  @@index([status, capability])
  @@index([lease_expires_at])
}

model AgentRun {
  id                 String         @id @default(cuid())
  project_id         String
  project            Project        @relation(fields: [project_id], references: [id], onDelete: Cascade)
  customer_id        String
  task_id            String
  task               Task           @relation(fields: [task_id], references: [id], onDelete: Cascade)
  agent_type         String
  status             AgentRunStatus @default(pending)
  runtime_seconds    Float?
  cost_cents       Int?
  output_artifact_id String?
  created_at         DateTime       @default(now())
  updated_at         DateTime       @updatedAt

  @@index([project_id])
  @@index([task_id])
  @@index([customer_id])
}

model DataNeed {
  id                     String         @id @default(cuid())
  project_id             String
  project                Project        @relation(fields: [project_id], references: [id], onDelete: Cascade)
  customer_id            String
  type                   String
  priority               String         @default("medium")
  description            String
  requestor_task_id      String?
  status                 DataNeedStatus @default(open)
  resolution_artifact_id String?
  resolution_notes       String?
  created_at             DateTime       @default(now())
  updated_at             DateTime       @updatedAt

  @@index([project_id, status])
  @@index([customer_id, status])
  @@index([status])
}

model Claim {
  id                        String            @id @default(cuid())
  project_id                String
  project                   Project           @relation(fields: [project_id], references: [id], onDelete: Cascade)
  customer_id               String
  workspace_version_id      String
  workspace_version         WorkspaceVersion  @relation(fields: [workspace_version_id], references: [id], onDelete: Cascade)
  artifact_id               String
  artifact                  Artifact          @relation(fields: [artifact_id], references: [id], onDelete: Cascade)
  type                      ClaimType
  text                      String
  status                    ClaimStatus       @default(draft)
  source_reliability        EvidenceReliability?
  source_coordinates        Json?
  metadata                  Json?
  invalidated_by_comment_id String?
  invalidated_by_comment    ReviewComment?    @relation("ClaimInvalidatedBy", fields: [invalidated_by_comment_id], references: [id])
  review_comments           ReviewComment[]   @relation("ReviewCommentTarget")
  created_at                DateTime          @default(now())
  updated_at                DateTime          @updatedAt

  evidence Evidence[]

  @@index([project_id])
  @@index([artifact_id])
  @@index([customer_id, type])
  @@index([status])
}

model ReviewComment {
  id                   String             @id @default(cuid())
  project_id           String
  project              Project            @relation(fields: [project_id], references: [id], onDelete: Cascade)
  customer_id          String
  workspace_version_id String
  workspace_version    WorkspaceVersion   @relation(fields: [workspace_version_id], references: [id], onDelete: Cascade)
  type                 ReviewCommentType
  text                 String
  target_claim_id      String?
  target_claim         Claim?             @relation("ReviewCommentTarget", fields: [target_claim_id], references: [id], onDelete: SetNull)
  invalidated_claims   Claim[]            @relation("ClaimInvalidatedBy")
  metadata             Json?
  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt

  @@index([project_id])
  @@index([workspace_version_id])
  @@index([customer_id])
  @@index([target_claim_id])
}

model Evidence {
  id                   String              @id @default(cuid())
  project_id           String
  project              Project             @relation(fields: [project_id], references: [id], onDelete: Cascade)
  customer_id          String
  claim_id             String
  claim                Claim               @relation(fields: [claim_id], references: [id], onDelete: Cascade)
  artifact_id          String
  artifact             Artifact            @relation(fields: [artifact_id], references: [id], onDelete: Cascade)
  source_coordinates   Json?
  content              String?
  reliability_category EvidenceReliability?
  created_at           DateTime            @default(now())

  @@index([project_id])
  @@index([claim_id])
  @@index([artifact_id])
}